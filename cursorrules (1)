## Validation Layer

Before ANY tool returns data to the user, run these checks:

```typescript
function validateOutput(data: ETFData): string[] {
  const errors: string[] = [];
  
  // 1. Ticker exists in master DB
  if (!masterDB.has(data.ticker)) 
    errors.push(`Unknown ticker: ${data.ticker}`);
  
  // 2. Name matches master DB
  const master = masterDB.get(data.ticker);
  if (master && data.name !== master.name)
    errors.push(`Name mismatch: got "${data.name}", expected "${master.name}"`);
  
  // 3. Brand-manager consistency
  if (master && !master.name.startsWith(data.brand))
    errors.push(`Brand mismatch`);
  
  // 4. Fee range (0% ~ 2%)
  if (data.total_fee < 0 || data.total_fee > 2)
    errors.push(`Fee out of range: ${data.total_fee}%`);
  
  // 5. Price sanity (positive, within 52-week range if available)
  if (data.price !== null && data.price <= 0)
    errors.push(`Invalid price: ${data.price}`);
  
  return errors;
}
```

